---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Fast local security guard for changed files, built-in rules, secrets scanning, and Semgrep-compatible YAML. Written in Rust.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-night text-smoke font-body antialiased min-h-screen grid-bg">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  html {
    scroll-behavior: smooth;
  }

  a {
    color: var(--color-fox);
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }

  code {
    font-family: var(--font-mono);
  }
</style>
