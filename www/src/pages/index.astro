---
import Base from '../layouts/Base.astro';

const jsRules = [
  { id: 'js/no-eval', cwe: 'CWE-95', desc: 'Use of eval() allows arbitrary code execution', severity: 'critical' },
  { id: 'js/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'js/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string concatenation or template literal', severity: 'critical' },
  { id: 'js/no-xss-innerhtml', cwe: 'CWE-79', desc: 'Assignment to innerHTML may lead to XSS', severity: 'high' },
  { id: 'js/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via exec/spawn with dynamic input', severity: 'critical' },
  { id: 'js/no-document-write', cwe: 'CWE-79', desc: 'document.write() with dynamic content enables XSS', severity: 'high' },
  { id: 'js/no-open-redirect', cwe: 'CWE-601', desc: 'Open redirect via user-controlled URL', severity: 'medium' },
  { id: 'js/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'js/no-path-traversal', cwe: 'CWE-22', desc: 'Path traversal via unsanitized user input', severity: 'high' },
  { id: 'js/no-ssrf', cwe: 'CWE-918', desc: 'SSRF via dynamic outbound request URL', severity: 'high' },
  { id: 'js/no-prototype-pollution', cwe: 'CWE-1321', desc: 'Prototype pollution via object merge', severity: 'high' },
  { id: 'js/no-unsafe-regex', cwe: 'CWE-1333', desc: 'ReDoS-vulnerable regular expression', severity: 'medium' },
  { id: 'js/no-cors-star', cwe: 'CWE-942', desc: 'Permissive CORS policy (Access-Control-Allow-Origin: *)', severity: 'medium' },
  { id: 'js/express-no-hardcoded-session-secret', cwe: 'CWE-798', desc: 'Hardcoded session secret in express-session config', severity: 'high' },
  { id: 'js/express-cookie-no-secure', cwe: 'CWE-614', desc: 'Cookie config missing secure flag', severity: 'medium' },
  { id: 'js/express-cookie-no-httponly', cwe: 'CWE-1004', desc: 'Cookie config missing httpOnly flag', severity: 'medium' },
  { id: 'js/express-cookie-no-samesite', cwe: 'CWE-352', desc: 'Cookie config missing a safe sameSite setting', severity: 'medium' },
  { id: 'js/express-session-saveuninitialized-true', cwe: 'CWE-359', desc: 'express-session configured with saveUninitialized: true', severity: 'medium' },
  { id: 'js/express-direct-response-write', cwe: 'CWE-79', desc: 'XSS via res.send/res.write with user input', severity: 'high' },
  { id: 'js/jwt-hardcoded-secret', cwe: 'CWE-798', desc: 'JWT signing or verification with a hardcoded secret', severity: 'high' },
  { id: 'js/jwt-none-algorithm', cwe: 'CWE-347', desc: 'JWT configured to use the none algorithm', severity: 'high' },
  { id: 'js/jwt-ignore-expiration', cwe: 'CWE-613', desc: 'JWT verification configured to ignore token expiration', severity: 'high' },
  { id: 'js/jwt-decode-without-verify', cwe: 'CWE-347', desc: 'JWT decoded without signature verification', severity: 'high' },
  { id: 'js/jwt-verify-missing-algorithms', cwe: 'CWE-347', desc: 'JWT verification without an explicit algorithms allowlist', severity: 'high' },
];

const pyRules = [
  { id: 'py/no-eval', cwe: 'CWE-95', desc: 'Use of eval()/exec() allows arbitrary code execution', severity: 'critical' },
  { id: 'py/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'py/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string formatting', severity: 'critical' },
  { id: 'py/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via os.system/subprocess', severity: 'critical' },
  { id: 'py/no-path-traversal', cwe: 'CWE-22', desc: 'Path traversal via unsanitized user input', severity: 'high' },
  { id: 'py/no-ssrf', cwe: 'CWE-918', desc: 'SSRF via dynamic outbound request URL', severity: 'high' },
  { id: 'py/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'py/no-pickle', cwe: 'CWE-502', desc: 'Deserialization of untrusted data via pickle', severity: 'high' },
  { id: 'py/no-yaml-load', cwe: 'CWE-502', desc: 'Unsafe yaml.load() without SafeLoader', severity: 'high' },
  { id: 'py/no-debug-true', cwe: 'CWE-489', desc: 'DEBUG=True left enabled in production config', severity: 'medium' },
  { id: 'py/no-open-redirect', cwe: 'CWE-601', desc: 'Open redirect via user-controlled URL', severity: 'medium' },
  { id: 'py/no-cors-star', cwe: 'CWE-942', desc: 'Permissive CORS policy (CORS_ALLOW_ALL_ORIGINS)', severity: 'medium' },
  { id: 'py/flask-debug-mode', cwe: 'CWE-489', desc: 'Flask app.run(debug=True) exposes debugger in production', severity: 'high' },
  { id: 'py/django-secret-key-hardcoded', cwe: 'CWE-798', desc: 'Django SECRET_KEY hardcoded in source', severity: 'high' },
  { id: 'py/flask-secret-key-hardcoded', cwe: 'CWE-798', desc: 'Flask SECRET_KEY hardcoded in source', severity: 'high' },
  { id: 'py/session-cookie-secure-disabled', cwe: 'CWE-614', desc: 'SESSION_COOKIE_SECURE disabled in source', severity: 'medium' },
  { id: 'py/session-cookie-httponly-disabled', cwe: 'CWE-1004', desc: 'SESSION_COOKIE_HTTPONLY disabled in source', severity: 'medium' },
  { id: 'py/session-cookie-samesite-disabled', cwe: 'CWE-352', desc: 'SESSION_COOKIE_SAMESITE disabled in source', severity: 'medium' },
  { id: 'py/csrf-cookie-secure-disabled', cwe: 'CWE-614', desc: 'CSRF_COOKIE_SECURE disabled in source', severity: 'medium' },
  { id: 'py/csrf-cookie-httponly-disabled', cwe: 'CWE-1004', desc: 'CSRF_COOKIE_HTTPONLY disabled in source', severity: 'medium' },
  { id: 'py/csrf-cookie-samesite-disabled', cwe: 'CWE-352', desc: 'CSRF_COOKIE_SAMESITE disabled in source', severity: 'medium' },
  { id: 'py/csrf-exempt', cwe: 'CWE-352', desc: 'View marked csrf_exempt', severity: 'high' },
  { id: 'py/wtf-csrf-disabled', cwe: 'CWE-352', desc: 'Flask-WTF CSRF protection disabled in source', severity: 'high' },
  { id: 'py/wtf-csrf-check-default-disabled', cwe: 'CWE-352', desc: 'Flask-WTF default CSRF checks disabled in source', severity: 'high' },
  { id: 'py/django-allowed-hosts-wildcard', cwe: 'CWE-346', desc: 'Django ALLOWED_HOSTS allows all hosts', severity: 'medium' },
  { id: 'py/secure-ssl-redirect-disabled', cwe: 'CWE-319', desc: 'Django SECURE_SSL_REDIRECT disabled in source', severity: 'medium' },
];

const goRules = [
  { id: 'go/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string concatenation or fmt.Sprintf', severity: 'critical' },
  { id: 'go/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via exec.Command with dynamic input', severity: 'critical' },
  { id: 'go/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'go/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'go/no-ssrf', cwe: 'CWE-918', desc: 'SSRF via http.Get/http.Post with variable URL', severity: 'high' },
  { id: 'go/insecure-tls-skip-verify', cwe: 'CWE-295', desc: 'TLS verification disabled with InsecureSkipVerify', severity: 'high' },
  { id: 'go/gin-no-trusted-proxies', cwe: 'CWE-346', desc: 'Gin engine without SetTrustedProxies', severity: 'medium' },
  { id: 'go/net-http-no-timeout', cwe: 'CWE-400', desc: 'http.ListenAndServe without timeout config', severity: 'medium' },
];

const totalRules = jsRules.length + pyRules.length + goRules.length;
const benchmarkRows = [
  { repo: 'express', files: 141, foxguard: 0.284, semgrep: 17.373, opengrep: null },
  { repo: 'flask', files: 83, foxguard: 0.084, semgrep: 7.325, opengrep: null },
  { repo: 'gin', files: 99, foxguard: 0.516, semgrep: 8.007, opengrep: null },
];
const benchmarkMax = Math.max(...benchmarkRows.flatMap((row) => [row.foxguard, row.semgrep, row.opengrep ?? 0]));
const frameworkGroups = [
  {
    title: 'Express / Node',
    desc: 'Session secret handling, cookie flags, reflected response writes, and JWT hardening checks for common Node auth flows.',
    badges: ['session', 'cookies', 'jwt', 'xss'],
  },
  {
    title: 'Flask / Django',
    desc: 'Secret key checks, debug mode, session cookie flags, CSRF cookie flags, and csrf_exempt coverage for common Python web apps.',
    badges: ['secret keys', 'csrf', 'session', 'debug'],
  },
  {
    title: 'Gin / net/http',
    desc: 'Trusted proxy config, missing timeouts, outbound request misuse, and TLS verification bypass coverage for Go services.',
    badges: ['proxies', 'timeouts', 'ssrf', 'tls'],
  },
];
const compatFeatures = [
  { label: 'Top-level rules', status: 'supported' },
  { label: 'pattern', status: 'supported' },
  { label: 'pattern-regex', status: 'supported' },
  { label: 'pattern-either', status: 'supported' },
  { label: 'pattern-not', status: 'supported' },
  { label: 'pattern-not-regex', status: 'supported' },
  { label: 'pattern-not-inside', status: 'supported' },
  { label: 'pattern-inside', status: 'supported' },
  { label: 'patterns', status: 'supported' },
  { label: 'paths.include/exclude', status: 'supported' },
  { label: 'metavariable-regex', status: 'supported' },
  { label: 'JS/TS, Python, Go', status: 'supported' },
  { label: 'Full Semgrep syntax', status: 'partial' },
];

function severityColor(s: string) {
  if (s === 'critical') return '#ef4444';
  if (s === 'high') return '#f97316';
  if (s === 'medium') return '#eab308';
  return '#737373';
}

function timeWidth(seconds: number | null) {
  if (seconds === null) return 0;
  return Math.max((seconds / benchmarkMax) * 100, 2);
}
---

<Base
  title="foxguard - Fast local security guard in Rust"
  description="Fast local security guard for changed files, built-in rules, secrets scanning, baselines, and Semgrep-compatible YAML."
>

  <!-- Hero -->
  <section class="relative pt-10 pb-18 sm:pt-14 sm:pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="fade-up flex items-center justify-between pb-8 text-sm">
        <div class="editorial-kicker">local-first sast</div>
        <div class="hidden md:flex items-center gap-5 font-mono text-[11px] uppercase tracking-[0.18em] text-noir-500">
          <a href="#speed" class="hover:text-noir-50 no-underline">speed</a>
          <a href="#compatibility" class="hover:text-noir-50 no-underline">compatibility</a>
          <a href="#rules" class="hover:text-noir-50 no-underline">rules</a>
          <a href="#install" class="hover:text-noir-50 no-underline">install</a>
        </div>
      </div>

      <div class="hero-frame fade-up fade-up-delay-1 p-6 sm:p-8 lg:p-10">
        <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
          <div class="text-left">
            <div class="mb-5 font-mono text-xs uppercase tracking-[0.05em] text-noir-500">
              Rust-native scanner for the edit-save-commit loop
            </div>
            <h1 class="font-heading text-noir-50 leading-[0.92] tracking-[-0.03em] mb-6" style="font-size: clamp(3.4rem, 8vw, 6.8rem);">
              fox<span class="text-fox-light">guard</span>
            </h1>
            <p class="max-w-xl text-lg sm:text-xl text-noir-300 mb-4">
              Fast local security guard.
            </p>
            <p class="max-w-2xl text-base sm:text-lg text-noir-400 leading-relaxed mb-8">
              Rust-native. {totalRules} built-in code rules. Secrets mode with excludes. Repo config. Semgrep-compatible. Single binary. Hook-friendly.
            </p>

            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8">
              <button
                id="npx-btn"
                class="group relative flex items-center gap-3 rounded-md border border-noir-800 bg-noir-950 px-5 py-3 font-mono text-sm text-fox-light transition-all duration-200 hover:border-noir-700 cursor-pointer"
              >
                <span class="text-noir-500">$</span>
                <span>npx foxguard .</span>
                <svg class="w-4 h-4 text-noir-500 group-hover:text-fox-light transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              </button>

              <a
                href="https://github.com/peaktwilight/foxguard"
                target="_blank"
                rel="noopener"
                class="btn-primary no-underline hover:no-underline"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                Star on GitHub
              </a>
            </div>

            <div class="grid gap-3 sm:grid-cols-3 mb-8">
              <div class="metric-pill">
                <div class="metric-label">Built-ins</div>
                <div class="metric-value">{totalRules}</div>
              </div>
              <div class="metric-pill">
                <div class="metric-label">Languages</div>
                <div class="metric-value">3</div>
              </div>
              <div class="metric-pill">
                <div class="metric-label">Outputs</div>
                <div class="metric-value">SARIF</div>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 font-mono text-xs text-noir-500">
              <span class="rounded-md bg-noir-900 border border-noir-800 px-3 py-1">foxguard init</span>
              <span class="rounded-md bg-noir-900 border border-noir-800 px-3 py-1">foxguard --changed .</span>
              <span class="rounded-md bg-noir-900 border border-noir-800 px-3 py-1">foxguard secrets --changed .</span>
              <span class="rounded-md bg-noir-900 border border-noir-800 px-3 py-1">.foxguard.yml</span>
            </div>
          </div>

          <div class="space-y-4">
            <div class="panel-editorial overflow-hidden">
              <div class="flex items-center gap-2 border-b border-noir-800 bg-noir-950 px-4 py-3">
                <span class="w-3 h-3 rounded-full bg-[#ef4444]"></span>
                <span class="w-3 h-3 rounded-full bg-[#eab308]"></span>
                <span class="w-3 h-3 rounded-full bg-[#22c55e]"></span>
                <span class="font-mono text-[11px] text-noir-500 mx-auto">terminal</span>
              </div>
              <div class="p-4 sm:p-5 font-mono text-[13px] leading-7 text-left">
                <div><span class="text-fox-light">$</span> <span class="text-noir-50">foxguard .</span></div>
                <div class="text-noir-500">Scanning 1,247 files...</div>
                <div class="h-4"></div>
                <div><span class="text-blue-300">src/auth/login.js</span><span class="text-noir-500">:14:5</span></div>
                <div class="pl-4"><span class="text-[#ef4444] font-semibold text-[11px] uppercase tracking-wide">critical</span> <span class="text-noir-200 ml-1">js/no-sql-injection</span> <span class="text-noir-500 ml-1">CWE-89</span></div>
                <div class="pl-4 text-noir-500">SQL query built with template literal interpolation</div>
                <div class="h-4"></div>
                <div><span class="text-blue-300">src/utils/config.py</span><span class="text-noir-500">:7:1</span></div>
                <div class="pl-4"><span class="text-[#f97316] font-semibold text-[11px] uppercase tracking-wide">high</span> <span class="text-noir-200 ml-1">py/no-hardcoded-secret</span> <span class="text-noir-500 ml-1">CWE-798</span></div>
                <div class="pl-4 text-noir-500">Hardcoded secret in 'api_key'</div>
                <div class="h-4"></div>
                <div><span class="text-blue-300">cmd/server.go</span><span class="text-noir-500">:42:3</span></div>
                <div class="pl-4"><span class="text-[#f97316] font-semibold text-[11px] uppercase tracking-wide">high</span> <span class="text-noir-200 ml-1">go/no-ssrf</span> <span class="text-noir-500 ml-1">CWE-918</span></div>
                <div class="pl-4 text-noir-500">Potential SSRF via http.Get with variable URL</div>
                <div class="h-4"></div>
                <div class="border-t border-noir-800 pt-3 mt-1">
                  Found <span class="text-fox-light font-semibold">3 issues</span> in <span class="text-fox-light font-semibold">1,247 files</span> <span class="text-noir-500">(0.84s)</span>
                </div>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div class="panel-editorial p-5 text-left">
                <div class="font-mono text-[11px] uppercase tracking-[0.05em] text-noir-500 mb-2">Default path</div>
                <div class="text-noir-50 font-semibold mb-2">Built-ins first</div>
                <p class="text-sm text-noir-400 leading-relaxed">Use the native rules for local feedback, then layer compatible YAML on top when you need alignment with an existing rule corpus.</p>
              </div>
              <div class="panel-editorial p-5 text-left">
                <div class="font-mono text-[11px] uppercase tracking-[0.05em] text-noir-500 mb-2">Adoption bridge</div>
                <div class="text-noir-50 font-semibold mb-2">Semgrep-compatible subset</div>
                <p class="text-sm text-noir-400 leading-relaxed">Load focused Semgrep/OpenGrep rules with path filters, regex clauses, and structural matching without pretending to replace the full ecosystem.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Speed -->
  <section class="py-20" id="speed">
    <div class="section-divider mb-20"></div>
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-heading text-3xl font-bold text-noir-50 mb-2">Fast by default</h2>
        <p class="text-noir-400 max-w-2xl mx-auto">
          Current local default-mode snapshot: foxguard built-ins vs Semgrep <code>auto</code>, with OpenGrep omitted here because it is not installed in this environment.
          For same-rules engine comparisons, use <code>BENCH_MODE=compat</code>.
        </p>
      </div>

      <div class="bg-noir-900 border border-noir-800 rounded-xl p-5 sm:p-6 mb-8">
        <div class="hidden md:grid grid-cols-[120px_1fr_1fr_1fr] gap-3 text-[11px] font-mono uppercase tracking-wider text-noir-500 mb-4 px-1">
          <div>Repo</div>
          <div>foxguard</div>
          <div>Semgrep</div>
          <div>OpenGrep</div>
        </div>

        <div class="flex flex-col gap-5">
          {benchmarkRows.map((row) => (
            <div class="grid grid-cols-1 md:grid-cols-[120px_1fr_1fr_1fr] gap-3 items-center">
              <div class="md:pr-3">
                <div class="font-mono text-noir-50 text-sm">{row.repo}</div>
                <div class="font-mono text-[11px] text-noir-500">{row.files} files</div>
              </div>

              {[
                { name: 'foxguard', time: row.foxguard, className: 'bg-fox text-noir-950' },
                { name: 'Semgrep', time: row.semgrep, className: 'bg-[#3b82f6] text-noir-50' },
                { name: 'OpenGrep', time: row.opengrep, className: 'bg-[#22c55e] text-noir-950' },
              ].map((tool) => (
                <div>
                  <div class="md:hidden font-mono text-[11px] uppercase tracking-wider text-noir-500 mb-2">{tool.name}</div>
                  <div class="bg-noir-950 rounded-lg border border-noir-800 overflow-hidden h-10 flex items-center">
                    {tool.time === null ? (
                      <div class="h-full w-full flex items-center justify-center px-3 text-xs font-mono text-noir-500">
                        N/A
                      </div>
                    ) : (
                      <div
                        class:list={['h-full flex items-center justify-end px-3 text-xs font-mono font-semibold min-w-[72px]', tool.className]}
                        style={`width: ${timeWidth(tool.time)}%`}
                      >
                        {tool.time.toFixed(3)}s
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
      <p class="text-xs text-noir-500 mb-12">
        Run <code>./benchmarks/run.sh</code> locally to refresh this snapshot. Missing competitor binaries show up as <code>N/A</code> instead of stale numbers.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
        <div class="bg-noir-900 border border-noir-800 rounded-xl p-5">
          <div class="text-xs font-mono font-bold text-noir-500 mb-3 tracking-wider">DEFAULT MODE</div>
          <h3 class="text-noir-50 font-semibold mb-2">Product comparison</h3>
          <p class="text-sm text-noir-400 leading-relaxed">
            Compare foxguard built-ins against Semgrep or OpenGrep <code>auto</code> rules to measure the tools the way users actually run them by default.
          </p>
        </div>
        <div class="bg-noir-900 border border-noir-800 rounded-xl p-5">
          <div class="text-xs font-mono font-bold text-fox mb-3 tracking-wider">COMPAT MODE</div>
          <h3 class="text-noir-50 font-semibold mb-2">Same-rules engine comparison</h3>
          <p class="text-sm text-noir-400 leading-relaxed">
            Run the same Semgrep-compatible YAML rules across foxguard, Semgrep, and OpenGrep with <code>--no-builtins --rules</code> for a narrower compatibility check.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
        {frameworkGroups.map((group) => (
          <div class="framework-card p-5 text-left">
            <div class="text-noir-50 font-semibold mb-2">{group.title}</div>
            <p class="text-sm text-noir-400 leading-relaxed mb-4">{group.desc}</p>
            <div class="flex flex-wrap gap-2">
              {group.badges.map((badge) => (
                <span class="framework-badge">{badge}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Local workflow diagram -->
      <div class="max-w-2xl mx-auto mb-10">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-0 font-mono text-sm">
          <div class="bg-noir-900 border border-noir-800 rounded-md px-4 py-3 text-noir-400">edit</div>
          <svg class="w-6 h-6 text-fox shrink-0 rotate-90 sm:rotate-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          <div class="bg-noir-900 border border-fox/20 rounded-md px-4 py-3 text-fox font-semibold">foxguard checks <span class="text-fox/60">(local-first)</span></div>
          <svg class="w-6 h-6 text-fox shrink-0 rotate-90 sm:rotate-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          <div class="bg-noir-900 border border-noir-800 rounded-md px-4 py-3 text-noir-400">fix</div>
          <svg class="w-6 h-6 text-fox shrink-0 rotate-90 sm:rotate-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          <div class="bg-noir-900 border border-noir-800 rounded-md px-4 py-3 text-noir-400">commit</div>
        </div>
      </div>

      <p class="text-noir-400 text-sm max-w-xl mx-auto text-center">
        The default story is built-ins-first. The compatibility story is bring-your-own YAML when you need to align with existing Semgrep or OpenGrep workflows.
      </p>
      <p class="text-noir-500 text-sm max-w-xl mx-auto text-center mt-3">
        Run <code>./benchmarks/run.sh</code> locally for current numbers and methodology.
      </p>
    </div>
  </section>

  <!-- Compatibility -->
  <section class="py-20" id="compatibility">
    <div class="section-divider mb-20"></div>
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl font-bold text-noir-50 mb-2">Compatibility, not magic</h2>
      <p class="text-noir-400 max-w-2xl mx-auto mb-10">
        foxguard can load a useful Semgrep-compatible subset today. The default product path is still built-in rules. External YAML is there to help teams adopt foxguard without starting from zero.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-4xl mx-auto mb-8">
        {compatFeatures.map((feature) => (
          <div class="bg-noir-900 border border-noir-800 rounded-xl p-4 text-left transition-colors hover:border-noir-700">
            <div class:list={[
              'font-mono text-[11px] uppercase tracking-wider mb-2',
              feature.status === 'supported' ? 'text-fox' : 'text-[#3b82f6]'
            ]}>
              {feature.status}
            </div>
            <div class="text-sm text-noir-50">{feature.label}</div>
          </div>
        ))}
      </div>

      <p class="text-noir-400 text-sm max-w-2xl mx-auto">
        If you need the full Semgrep or OpenGrep rule universe, use those tools directly. If you want fast local feedback with a compatibility bridge, that is where foxguard fits.
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20" id="features">
    <div class="section-divider mb-20"></div>
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl font-bold text-noir-50 mb-2">Features</h2>
      <p class="text-noir-400 mb-10">Local-first security checks for the edit-save-commit loop.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { icon: '< 60ms', title: 'Single binary, local-first', desc: 'No JVM, no Python runtime, no network calls. Fast enough for edit-save-commit loops, hooks, and scripts.' },
          { icon: 'hook', title: 'Pre-commit ready', desc: 'Install a repo-local hook with foxguard init and get a starter .foxguard.yml for changed-file scans.' },
          { icon: '.yaml', title: 'Bring your own rules', desc: 'Built-ins are the default. Add a useful Semgrep-compatible YAML subset from a file or directory when needed.' },
          { icon: '56', title: 'Built-in coverage', desc: 'Security checks for JS/TS, Python, and Go, including SSRF client variants, path traversal sinks, auth, session, CSRF, transport, and framework-specific rules.' },
          { icon: 'base', title: 'Baseline adoption', desc: 'Accept existing findings once and focus on new ones with a baseline file.' },
          { icon: 'secret', title: 'Secrets mode', desc: 'Scan for common leaked credentials and private key material with redacted output and binary-safe handling.' },
          { icon: 'SARIF', title: 'CI-friendly output', desc: 'Use terminal output locally or JSON and SARIF in automation.' },
        ].map((f) => (
          <div class="group bg-noir-900 border border-noir-800 rounded-xl p-6 hover:border-noir-700 transition-all duration-300">
            <div class="text-xs font-mono font-bold text-fox mb-3 tracking-wider">{f.icon}</div>
            <h3 class="text-noir-50 font-semibold mb-2">{f.title}</h3>
            <p class="text-sm text-noir-400 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Positioning -->
  <section class="py-20" id="positioning">
    <div class="section-divider mb-20"></div>
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-heading text-3xl font-bold text-noir-50 mb-2">Where It Fits</h2>
        <p class="text-noir-400">foxguard is best positioned as a local-first complement, not a claim of full tool replacement.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="bg-noir-900 border border-noir-800 rounded-xl p-6 transition-colors hover:border-noir-700">
          <div class="text-xs font-mono font-bold text-noir-500 mb-3 tracking-wider">SEMGREP / OPENGREP</div>
          <h3 class="text-noir-50 font-semibold mb-3">Broad ecosystem coverage</h3>
          <div class="flex flex-col gap-2 text-sm text-noir-400">
            <div>Large existing rule ecosystems</div>
            <div>Strong CI and platform fit</div>
            <div>Broader language and analysis scope</div>
          </div>
        </div>
        <div class="bg-noir-900 border border-fox/20 rounded-xl p-6 transition-colors hover:border-fox/30">
          <div class="text-xs font-mono font-bold text-fox mb-3 tracking-wider">FOXGUARD</div>
          <h3 class="text-noir-50 font-semibold mb-3">Fast local feedback on a Rust engine</h3>
          <div class="flex flex-col gap-2 text-sm text-noir-400">
            <div>Useful built-in rules out of the box</div>
            <div>Terminal, JSON, and SARIF output</div>
            <div>Semgrep-compatible YAML subset loading with <code>--rules</code></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Install -->
  <section class="py-20" id="install">
    <div class="section-divider mb-20"></div>
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl font-bold text-noir-50 mb-2">Install</h2>
      <p class="text-noir-400 mb-10">Get started in seconds.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <div class="bg-noir-900 border border-noir-800 rounded-xl p-5">
          <div class="text-xs font-semibold text-noir-500 uppercase tracking-wider mb-3">Rust / Cargo</div>
          <div class="flex items-center justify-between bg-noir-950 border border-noir-800 rounded-md px-4 py-3 font-mono text-sm text-fox">
            <code>cargo install foxguard</code>
            <button class="copy-btn text-noir-500 hover:text-noir-50 transition-colors cursor-pointer" data-copy="cargo install foxguard" aria-label="Copy">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
          </div>
        </div>
        <div class="bg-noir-900 border border-noir-800 rounded-xl p-5">
          <div class="text-xs font-semibold text-noir-500 uppercase tracking-wider mb-3">npm / npx</div>
          <div class="flex items-center justify-between bg-noir-950 border border-noir-800 rounded-md px-4 py-3 font-mono text-sm text-fox">
            <code>npx foxguard .</code>
            <button class="copy-btn text-noir-500 hover:text-noir-50 transition-colors cursor-pointer" data-copy="npx foxguard ." aria-label="Copy">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rules -->
  <section class="py-20" id="rules">
    <div class="section-divider mb-20"></div>
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl font-bold text-noir-50 mb-2">Rules</h2>
      <p class="text-noir-400 mb-10">{totalRules} rules across 3 languages, each mapped to a CWE identifier</p>

      <div class="flex flex-col gap-3">
        {[
          { name: 'JavaScript / TypeScript', rules: jsRules, count: jsRules.length },
          { name: 'Python', rules: pyRules, count: pyRules.length },
          { name: 'Go', rules: goRules, count: goRules.length },
        ].map((group) => (
          <details class="group bg-noir-900 border border-noir-800 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none font-semibold hover:bg-noir-800/50 transition-colors">
              <span class="flex items-center gap-3">
                <svg class="w-3 h-3 text-noir-500 transition-transform duration-200 group-open:rotate-90" viewBox="0 0 12 12" fill="currentColor"><path d="M4 1l6 5-6 5V1z"/></svg>
                <span class="text-noir-50">{group.name}</span>
              </span>
              <span class="font-mono text-xs text-noir-500 font-normal">{group.count} rules</span>
            </summary>
            <div class="border-t border-noir-800">
              {group.rules.map((rule) => (
                <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto_auto_2fr] gap-x-3 gap-y-1 items-center px-5 py-2.5 text-[13px] border-b border-noir-800/50 last:border-b-0">
                  <code class="font-mono text-fox text-[13px]">{rule.id}</code>
                  <span class="font-mono text-[11px] font-semibold uppercase" style={`color: ${severityColor(rule.severity)}`}>{rule.severity}</span>
                  <span class="font-mono text-[11px] text-noir-500">{rule.cwe}</span>
                  <span class="text-noir-400 text-[13px] hidden sm:block">{rule.desc}</span>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center">
    <div class="section-divider mb-20"></div>
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="font-heading text-3xl font-bold text-noir-50 mb-3">Open source. MIT licensed.</h2>
      <p class="text-noir-400 mb-8">Star us on GitHub and help make codebases safer.</p>
      <a
        href="https://github.com/peaktwilight/foxguard"
        target="_blank"
        rel="noopener"
        class="btn-primary no-underline hover:no-underline"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        Star on GitHub
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 text-center text-sm text-noir-500">
    <div class="section-divider mb-8"></div>
    <div class="max-w-5xl mx-auto px-6">
      <span>MIT License</span>
      <span class="mx-2 opacity-30">|</span>
      <span>Made by <a href="https://github.com/peaktwilight" class="text-fox hover:text-fox-light">Peak Twilight</a></span>
      <span class="mx-2 opacity-30">|</span>
      <span>foxguard.dev</span>
    </div>
  </footer>

  <script>
    // Copy buttons
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || '';
        navigator.clipboard.writeText(text);
        btn.classList.add('text-fox');
        setTimeout(() => btn.classList.remove('text-fox'), 1500);
      });
    });

    // npx copy button
    const npxBtn = document.getElementById('npx-btn');
    if (npxBtn) {
      npxBtn.addEventListener('click', () => {
        navigator.clipboard.writeText('npx foxguard .');
        const original = npxBtn.innerHTML;
        npxBtn.querySelector('span:nth-child(2)')!.textContent = 'Copied!';
        setTimeout(() => {
          npxBtn.querySelector('span:nth-child(2)')!.textContent = 'npx foxguard .';
        }, 1500);
      });
    }
  </script>
</Base>
