---
import Base from '../layouts/Base.astro';

const jsRules = [
  { id: 'js/no-eval', cwe: 'CWE-95', desc: 'Use of eval() allows arbitrary code execution', severity: 'critical' },
  { id: 'js/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'js/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string concatenation or template literal', severity: 'critical' },
  { id: 'js/no-xss-innerhtml', cwe: 'CWE-79', desc: 'Assignment to innerHTML may lead to XSS', severity: 'high' },
  { id: 'js/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via exec/spawn with dynamic input', severity: 'critical' },
  { id: 'js/no-document-write', cwe: 'CWE-79', desc: 'document.write() with dynamic content enables XSS', severity: 'high' },
  { id: 'js/no-open-redirect', cwe: 'CWE-601', desc: 'Open redirect via user-controlled URL', severity: 'medium' },
  { id: 'js/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'js/no-path-traversal', cwe: 'CWE-22', desc: 'Path traversal via unsanitized user input', severity: 'high' },
  { id: 'js/no-ssrf', cwe: 'CWE-918', desc: 'SSRF via dynamic outbound request URL', severity: 'high' },
  { id: 'js/no-prototype-pollution', cwe: 'CWE-1321', desc: 'Prototype pollution via object merge', severity: 'high' },
  { id: 'js/no-unsafe-regex', cwe: 'CWE-1333', desc: 'ReDoS-vulnerable regular expression', severity: 'medium' },
  { id: 'js/no-cors-star', cwe: 'CWE-942', desc: 'Permissive CORS policy (Access-Control-Allow-Origin: *)', severity: 'medium' },
  { id: 'js/express-no-hardcoded-session-secret', cwe: 'CWE-798', desc: 'Hardcoded session secret in express-session config', severity: 'high' },
  { id: 'js/express-cookie-no-secure', cwe: 'CWE-614', desc: 'Cookie config missing secure flag', severity: 'medium' },
  { id: 'js/express-cookie-no-httponly', cwe: 'CWE-1004', desc: 'Cookie config missing httpOnly flag', severity: 'medium' },
  { id: 'js/express-cookie-no-samesite', cwe: 'CWE-352', desc: 'Cookie config missing a safe sameSite setting', severity: 'medium' },
  { id: 'js/express-direct-response-write', cwe: 'CWE-79', desc: 'XSS via res.send/res.write with user input', severity: 'high' },
  { id: 'js/jwt-hardcoded-secret', cwe: 'CWE-798', desc: 'JWT signing or verification with a hardcoded secret', severity: 'high' },
];

const pyRules = [
  { id: 'py/no-eval', cwe: 'CWE-95', desc: 'Use of eval()/exec() allows arbitrary code execution', severity: 'critical' },
  { id: 'py/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'py/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string formatting', severity: 'critical' },
  { id: 'py/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via os.system/subprocess', severity: 'critical' },
  { id: 'py/no-path-traversal', cwe: 'CWE-22', desc: 'Path traversal via unsanitized user input', severity: 'high' },
  { id: 'py/no-ssrf', cwe: 'CWE-918', desc: 'SSRF via dynamic outbound request URL', severity: 'high' },
  { id: 'py/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'py/no-pickle', cwe: 'CWE-502', desc: 'Deserialization of untrusted data via pickle', severity: 'high' },
  { id: 'py/no-yaml-load', cwe: 'CWE-502', desc: 'Unsafe yaml.load() without SafeLoader', severity: 'high' },
  { id: 'py/no-debug-true', cwe: 'CWE-489', desc: 'DEBUG=True left enabled in production config', severity: 'medium' },
  { id: 'py/no-open-redirect', cwe: 'CWE-601', desc: 'Open redirect via user-controlled URL', severity: 'medium' },
  { id: 'py/no-cors-star', cwe: 'CWE-942', desc: 'Permissive CORS policy (CORS_ALLOW_ALL_ORIGINS)', severity: 'medium' },
  { id: 'py/flask-debug-mode', cwe: 'CWE-489', desc: 'Flask app.run(debug=True) exposes debugger in production', severity: 'high' },
  { id: 'py/django-secret-key-hardcoded', cwe: 'CWE-798', desc: 'Django SECRET_KEY hardcoded in source', severity: 'high' },
  { id: 'py/flask-secret-key-hardcoded', cwe: 'CWE-798', desc: 'Flask SECRET_KEY hardcoded in source', severity: 'high' },
  { id: 'py/session-cookie-secure-disabled', cwe: 'CWE-614', desc: 'SESSION_COOKIE_SECURE disabled in source', severity: 'medium' },
];

const goRules = [
  { id: 'go/no-sql-injection', cwe: 'CWE-89', desc: 'SQL injection via string concatenation or fmt.Sprintf', severity: 'critical' },
  { id: 'go/no-command-injection', cwe: 'CWE-78', desc: 'Command injection via exec.Command with dynamic input', severity: 'critical' },
  { id: 'go/no-hardcoded-secret', cwe: 'CWE-798', desc: 'Hardcoded secret or credential detected', severity: 'high' },
  { id: 'go/no-weak-crypto', cwe: 'CWE-327', desc: 'Use of weak cryptographic hash (MD5/SHA1)', severity: 'medium' },
  { id: 'go/no-ssrf', cwe: 'CWE-918', desc: 'SSRF via http.Get/http.Post with variable URL', severity: 'high' },
  { id: 'go/insecure-tls-skip-verify', cwe: 'CWE-295', desc: 'TLS verification disabled with InsecureSkipVerify', severity: 'high' },
  { id: 'go/gin-no-trusted-proxies', cwe: 'CWE-346', desc: 'Gin engine without SetTrustedProxies', severity: 'medium' },
  { id: 'go/net-http-no-timeout', cwe: 'CWE-400', desc: 'http.ListenAndServe without timeout config', severity: 'medium' },
];

const totalRules = jsRules.length + pyRules.length + goRules.length;
const benchmarkRows = [
  { repo: 'express', files: 141, foxguard: 0.079, semgrep: 4.712, opengrep: 4.756 },
  { repo: 'flask', files: 83, foxguard: 0.049, semgrep: 4.702, opengrep: 5.150 },
  { repo: 'gin', files: 99, foxguard: 0.065, semgrep: 4.467, opengrep: 4.294 },
];
const benchmarkMax = Math.max(...benchmarkRows.flatMap((row) => [row.foxguard, row.semgrep, row.opengrep]));
const compatFeatures = [
  { label: 'Top-level rules', status: 'supported' },
  { label: 'pattern', status: 'supported' },
  { label: 'pattern-either', status: 'supported' },
  { label: 'pattern-not', status: 'supported' },
  { label: 'pattern-inside', status: 'supported' },
  { label: 'patterns', status: 'supported' },
  { label: 'JS/TS, Python, Go', status: 'supported' },
  { label: 'Full Semgrep syntax', status: 'partial' },
];

function severityColor(s: string) {
  if (s === 'critical') return '#ef4444';
  if (s === 'high') return '#f97316';
  if (s === 'medium') return '#eab308';
  return '#737373';
}

function timeWidth(seconds: number) {
  return Math.max((seconds / benchmarkMax) * 100, 2);
}
---

<Base
  title="foxguard - Fast local security guard in Rust"
  description="Fast local security guard for changed files, built-in rules, secrets scanning, baselines, and Semgrep-compatible YAML."
>

  <!-- Hero -->
  <section class="relative pt-24 pb-16 sm:pt-32 sm:pb-20">
    <div class="max-w-5xl mx-auto px-6 text-center">

      <!-- Fox icon -->
      <div class="fade-up mb-8 flex justify-center">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 8L20 28L32 20L44 28L56 8L52 32L44 44L36 52H28L20 44L12 32L8 8Z" fill="#F59E0B" fill-opacity="0.15" stroke="#F59E0B" stroke-width="2" stroke-linejoin="round"/>
          <circle cx="24" cy="32" r="2.5" fill="#F59E0B"/>
          <circle cx="40" cy="32" r="2.5" fill="#F59E0B"/>
          <path d="M28 40L32 44L36 40" stroke="#F59E0B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Badge -->
      <div class="fade-up fade-up-delay-1 mb-6">
        <span class="inline-block font-mono text-xs text-fox border border-fox/30 rounded-full px-3 py-1 tracking-wide">
          Written in Rust
        </span>
      </div>

      <!-- Title -->
      <h1 class="fade-up fade-up-delay-2 font-heading font-900 text-white leading-none tracking-tight mb-6" style="font-size: clamp(3.5rem, 12vw, 7rem);">
        fox<span class="text-fox">guard</span>
      </h1>

      <!-- Tagline -->
      <p class="fade-up fade-up-delay-3 text-lg sm:text-xl text-smoke max-w-2xl mx-auto mb-4">
        Fast local security guard.
      </p>
      <p class="fade-up fade-up-delay-3 text-sm sm:text-base text-ash max-w-xl mx-auto mb-10">
        Rust-native. 43 built-in code rules. Secrets mode. Semgrep-compatible. Single binary. Hook-friendly.
      </p>

      <!-- npx copy button -->
      <div class="fade-up fade-up-delay-4 flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
        <button
          id="npx-btn"
          class="group relative flex items-center gap-3 bg-night-light border border-night-lighter hover:border-fox/30 rounded-lg px-5 py-3 font-mono text-sm text-fox transition-all duration-200 cursor-pointer"
        >
          <span class="text-ash">$</span>
          <span>npx foxguard .</span>
          <svg class="w-4 h-4 text-ash group-hover:text-fox transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        </button>

        <!-- GitHub star button -->
        <a
          href="https://github.com/peaktwilight/foxguard"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 bg-white text-black font-semibold rounded-lg px-5 py-3 text-sm hover:bg-white/90 transition-colors no-underline hover:no-underline"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>

      <div class="fade-up fade-up-delay-4 flex flex-wrap items-center justify-center gap-3 mb-12 font-mono text-xs text-ash">
        <span class="bg-night-light border border-night-lighter rounded-full px-3 py-1">foxguard init</span>
        <span class="bg-night-light border border-night-lighter rounded-full px-3 py-1">foxguard --changed .</span>
        <span class="bg-night-light border border-night-lighter rounded-full px-3 py-1">foxguard secrets --changed .</span>
        <span class="bg-night-light border border-night-lighter rounded-full px-3 py-1">foxguard baseline --output .foxguard/baseline.json</span>
      </div>

      <!-- Terminal -->
      <div class="fade-up fade-up-delay-5 max-w-2xl mx-auto">
        <div class="rounded-xl border border-night-lighter overflow-hidden bg-[#0d0d0d] shadow-2xl shadow-fox/5">
          <!-- Terminal title bar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-night-light border-b border-night-lighter">
            <span class="w-3 h-3 rounded-full bg-[#ef4444]"></span>
            <span class="w-3 h-3 rounded-full bg-[#eab308]"></span>
            <span class="w-3 h-3 rounded-full bg-[#22c55e]"></span>
            <span class="font-mono text-[11px] text-ash mx-auto">terminal</span>
          </div>
          <!-- Terminal body -->
          <div class="p-4 sm:p-5 font-mono text-[13px] leading-7 text-left">
            <div><span class="text-fox">$</span> <span class="text-white">foxguard .</span></div>
            <div class="text-ash">Scanning 1,247 files...</div>
            <div class="h-4"></div>
            <div><span class="text-blue-400">src/auth/login.js</span><span class="text-ash">:14:5</span></div>
            <div class="pl-4"><span class="text-[#ef4444] font-semibold text-[11px] uppercase tracking-wide">critical</span> <span class="text-white/90 ml-1">js/no-sql-injection</span> <span class="text-ash ml-1">CWE-89</span></div>
            <div class="pl-4 text-ash">SQL query built with template literal interpolation</div>
            <div class="h-4"></div>
            <div><span class="text-blue-400">src/utils/config.py</span><span class="text-ash">:7:1</span></div>
            <div class="pl-4"><span class="text-[#f97316] font-semibold text-[11px] uppercase tracking-wide">high</span> <span class="text-white/90 ml-1">py/no-hardcoded-secret</span> <span class="text-ash ml-1">CWE-798</span></div>
            <div class="pl-4 text-ash">Hardcoded secret in 'api_key'</div>
            <div class="h-4"></div>
            <div><span class="text-blue-400">cmd/server.go</span><span class="text-ash">:42:3</span></div>
            <div class="pl-4"><span class="text-[#f97316] font-semibold text-[11px] uppercase tracking-wide">high</span> <span class="text-white/90 ml-1">go/no-ssrf</span> <span class="text-ash ml-1">CWE-918</span></div>
            <div class="pl-4 text-ash">Potential SSRF via http.Get with variable URL</div>
            <div class="h-4"></div>
            <div class="border-t border-night-lighter pt-3 mt-1">
              Found <span class="text-fox font-semibold">3 issues</span> in <span class="text-fox font-semibold">1,247 files</span> <span class="text-ash">(0.84s)</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Speed -->
  <section class="py-20 border-t border-night-lighter" id="speed">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-heading text-3xl font-bold text-white mb-2">Fast by default</h2>
        <p class="text-ash max-w-2xl mx-auto">
          Example local default-mode benchmark: foxguard built-ins vs Semgrep and OpenGrep <code>auto</code>.
          For same-rules engine comparisons, use <code>BENCH_MODE=compat</code>.
        </p>
      </div>

      <div class="bg-night-light border border-night-lighter rounded-2xl p-5 sm:p-6 mb-8">
        <div class="hidden md:grid grid-cols-[120px_1fr_1fr_1fr] gap-3 text-[11px] font-mono uppercase tracking-wider text-ash mb-4 px-1">
          <div>Repo</div>
          <div>foxguard</div>
          <div>Semgrep</div>
          <div>OpenGrep</div>
        </div>

        <div class="flex flex-col gap-5">
          {benchmarkRows.map((row) => (
            <div class="grid grid-cols-1 md:grid-cols-[120px_1fr_1fr_1fr] gap-3 items-center">
              <div class="md:pr-3">
                <div class="font-mono text-white text-sm">{row.repo}</div>
                <div class="font-mono text-[11px] text-ash">{row.files} files</div>
              </div>

              {[
                { name: 'foxguard', time: row.foxguard, className: 'bg-fox text-night' },
                { name: 'Semgrep', time: row.semgrep, className: 'bg-[#3b82f6] text-white' },
                { name: 'OpenGrep', time: row.opengrep, className: 'bg-[#22c55e] text-night' },
              ].map((tool) => (
                <div>
                  <div class="md:hidden font-mono text-[11px] uppercase tracking-wider text-ash mb-2">{tool.name}</div>
                  <div class="bg-night rounded-lg border border-night-lighter overflow-hidden h-10 flex items-center">
                    <div
                      class:list={['h-full flex items-center justify-end px-3 text-xs font-mono font-semibold min-w-[72px]', tool.className]}
                      style={`width: ${timeWidth(tool.time)}%`}
                    >
                      {tool.time.toFixed(3)}s
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
        <div class="bg-night-light border border-night-lighter rounded-xl p-5">
          <div class="text-xs font-mono font-bold text-ash mb-3 tracking-wider">DEFAULT MODE</div>
          <h3 class="text-white font-semibold mb-2">Product comparison</h3>
          <p class="text-sm text-ash leading-relaxed">
            Compare foxguard built-ins against Semgrep or OpenGrep <code>auto</code> rules to measure the tools the way users actually run them by default.
          </p>
        </div>
        <div class="bg-night-light border border-night-lighter rounded-xl p-5">
          <div class="text-xs font-mono font-bold text-fox mb-3 tracking-wider">COMPAT MODE</div>
          <h3 class="text-white font-semibold mb-2">Same-rules engine comparison</h3>
          <p class="text-sm text-ash leading-relaxed">
            Run the same Semgrep-compatible YAML rules across foxguard, Semgrep, and OpenGrep with <code>--no-builtins --rules</code> for a narrower compatibility check.
          </p>
        </div>
      </div>

      <!-- Local workflow diagram -->
      <div class="max-w-2xl mx-auto mb-10">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-0 font-mono text-sm">
          <div class="bg-night-light border border-night-lighter rounded-lg px-4 py-3 text-ash">edit</div>
          <svg class="w-6 h-6 text-fox shrink-0 rotate-90 sm:rotate-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          <div class="bg-fox/10 border border-fox/30 rounded-lg px-4 py-3 text-fox font-semibold">foxguard checks <span class="text-fox/70">(local-first)</span></div>
          <svg class="w-6 h-6 text-fox shrink-0 rotate-90 sm:rotate-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          <div class="bg-night-light border border-night-lighter rounded-lg px-4 py-3 text-ash">fix</div>
          <svg class="w-6 h-6 text-fox shrink-0 rotate-90 sm:rotate-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          <div class="bg-night-light border border-night-lighter rounded-lg px-4 py-3 text-ash">commit</div>
        </div>
      </div>

      <p class="text-ash text-sm max-w-xl mx-auto text-center">
        The default story is built-ins-first. The compatibility story is bring-your-own YAML when you need to align with existing Semgrep or OpenGrep workflows.
      </p>
      <p class="text-ash text-sm max-w-xl mx-auto text-center mt-3">
        Run <code>./benchmarks/run.sh</code> locally for current numbers and methodology.
      </p>
    </div>
  </section>

  <!-- Compatibility -->
  <section class="py-20 border-t border-night-lighter" id="compatibility">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl font-bold text-white mb-2">Compatibility, not magic</h2>
      <p class="text-ash max-w-2xl mx-auto mb-10">
        foxguard can load a useful Semgrep-compatible subset today. The default product path is still built-in rules. External YAML is there to help teams adopt foxguard without starting from zero.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-4xl mx-auto mb-8">
        {compatFeatures.map((feature) => (
          <div class="bg-night-light border border-night-lighter rounded-xl p-4 text-left">
            <div class:list={[
              'font-mono text-[11px] uppercase tracking-wider mb-2',
              feature.status === 'supported' ? 'text-fox' : 'text-[#3b82f6]'
            ]}>
              {feature.status}
            </div>
            <div class="text-sm text-white">{feature.label}</div>
          </div>
        ))}
      </div>

      <p class="text-ash text-sm max-w-2xl mx-auto">
        If you need the full Semgrep or OpenGrep rule universe, use those tools directly. If you want fast local feedback with a compatibility bridge, that is where foxguard fits.
      </p>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 border-t border-night-lighter" id="features">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl font-bold text-white mb-2">Features</h2>
      <p class="text-ash mb-10">Local-first security checks for the edit-save-commit loop.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { icon: '< 60ms', title: 'Single binary, local-first', desc: 'No JVM, no Python runtime, no network calls. Fast enough for edit-save-commit loops, hooks, and scripts.' },
          { icon: 'hook', title: 'Pre-commit ready', desc: 'Install a repo-local hook with foxguard init and scan changed files before commit.' },
          { icon: '.yaml', title: 'Bring your own rules', desc: 'Built-ins are the default. Add a useful Semgrep-compatible YAML subset from a file or directory when needed.' },
          { icon: '43', title: 'Built-in coverage', desc: 'Security checks for JS/TS, Python, and Go, including SSRF client variants, path traversal sinks, auth, session, transport, and framework-specific rules.' },
          { icon: 'base', title: 'Baseline adoption', desc: 'Accept existing findings once and focus on new ones with a baseline file.' },
          { icon: 'secret', title: 'Secrets mode', desc: 'Scan for common leaked credentials and private key material with redacted output and binary-safe handling.' },
          { icon: 'SARIF', title: 'CI-friendly output', desc: 'Use terminal output locally or JSON and SARIF in automation.' },
        ].map((f) => (
          <div class="group bg-night-light border border-night-lighter rounded-xl p-6 hover:border-fox/20 transition-colors">
            <div class="text-xs font-mono font-bold text-fox mb-3 tracking-wider">{f.icon}</div>
            <h3 class="text-white font-semibold mb-2">{f.title}</h3>
            <p class="text-sm text-ash leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Positioning -->
  <section class="py-20 border-t border-night-lighter" id="positioning">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="font-heading text-3xl font-bold text-white mb-2">Where It Fits</h2>
        <p class="text-ash">foxguard is best positioned as a local-first complement, not a claim of full tool replacement.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="bg-night-light border border-night-lighter rounded-xl p-6">
          <div class="text-xs font-mono font-bold text-ash mb-3 tracking-wider">SEMGREP / OPENGREP</div>
          <h3 class="text-white font-semibold mb-3">Broad ecosystem coverage</h3>
          <div class="flex flex-col gap-2 text-sm text-ash">
            <div>Large existing rule ecosystems</div>
            <div>Strong CI and platform fit</div>
            <div>Broader language and analysis scope</div>
          </div>
        </div>
        <div class="bg-night-light border border-fox/25 rounded-xl p-6 shadow-[0_0_0_1px_rgba(245,158,11,0.06)]">
          <div class="text-xs font-mono font-bold text-fox mb-3 tracking-wider">FOXGUARD</div>
          <h3 class="text-white font-semibold mb-3">Fast local feedback on a Rust engine</h3>
          <div class="flex flex-col gap-2 text-sm text-ash">
            <div>Useful built-in rules out of the box</div>
            <div>Terminal, JSON, and SARIF output</div>
            <div>Semgrep-compatible YAML subset loading with <code>--rules</code></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Install -->
  <section class="py-20 border-t border-night-lighter" id="install">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl font-bold text-white mb-2">Install</h2>
      <p class="text-ash mb-10">Get started in seconds.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <div class="bg-night-light border border-night-lighter rounded-xl p-5">
          <div class="text-xs font-semibold text-ash uppercase tracking-wider mb-3">Rust / Cargo</div>
          <div class="flex items-center justify-between bg-night border border-night-lighter rounded-lg px-4 py-3 font-mono text-sm text-fox">
            <code>cargo install foxguard</code>
            <button class="copy-btn text-ash hover:text-white transition-colors cursor-pointer" data-copy="cargo install foxguard" aria-label="Copy">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
          </div>
        </div>
        <div class="bg-night-light border border-night-lighter rounded-xl p-5">
          <div class="text-xs font-semibold text-ash uppercase tracking-wider mb-3">npm / npx</div>
          <div class="flex items-center justify-between bg-night border border-night-lighter rounded-lg px-4 py-3 font-mono text-sm text-fox">
            <code>npx foxguard .</code>
            <button class="copy-btn text-ash hover:text-white transition-colors cursor-pointer" data-copy="npx foxguard ." aria-label="Copy">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rules -->
  <section class="py-20 border-t border-night-lighter" id="rules">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl font-bold text-white mb-2">Rules</h2>
      <p class="text-ash mb-10">{totalRules} rules across 3 languages, each mapped to a CWE identifier</p>

      <div class="flex flex-col gap-3">
        {[
          { name: 'JavaScript / TypeScript', rules: jsRules, count: jsRules.length },
          { name: 'Python', rules: pyRules, count: pyRules.length },
          { name: 'Go', rules: goRules, count: goRules.length },
        ].map((group) => (
          <details class="group bg-night-light border border-night-lighter rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none font-semibold">
              <span class="flex items-center gap-3">
                <svg class="w-3 h-3 text-ash transition-transform duration-200 group-open:rotate-90" viewBox="0 0 12 12" fill="currentColor"><path d="M4 1l6 5-6 5V1z"/></svg>
                <span class="text-white">{group.name}</span>
              </span>
              <span class="font-mono text-xs text-ash font-normal">{group.count} rules</span>
            </summary>
            <div class="border-t border-night-lighter">
              {group.rules.map((rule) => (
                <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto_auto_2fr] gap-x-3 gap-y-1 items-center px-5 py-2.5 text-[13px] border-b border-night-light last:border-b-0">
                  <code class="font-mono text-fox text-[13px]">{rule.id}</code>
                  <span class="font-mono text-[11px] font-semibold uppercase" style={`color: ${severityColor(rule.severity)}`}>{rule.severity}</span>
                  <span class="font-mono text-[11px] text-ash">{rule.cwe}</span>
                  <span class="text-ash text-[13px] hidden sm:block">{rule.desc}</span>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-night-lighter text-center">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="font-heading text-3xl font-bold text-white mb-3">Open source. MIT licensed.</h2>
      <p class="text-ash mb-8">Star us on GitHub and help make codebases safer.</p>
