---
interface Props {
  severity: string;
}

const { severity } = Astro.props;

const colors: Record<string, string> = {
  critical: '#ef4444',
  high: '#f97316',
  medium: '#eab308',
  low: '#737373',
};
---

<span
  class="font-mono text-[10px] font-semibold uppercase tracking-wide"
  style={`color: ${colors[severity] ?? colors.low}`}
>
  {severity}
</span>
