---
import SiteNav from '../ui/SiteNav.astro';
import InstallTabs from '../ui/InstallTabs.astro';
---

<section class="flex items-center justify-center text-center min-h-[calc(100svh-6rem)] px-6 pb-12 overflow-x-hidden">
  <div class="w-full min-w-0 max-w-3xl mx-auto">
    <h1 class="font-heading text-noir-50 text-3xl sm:text-5xl lg:text-6xl leading-[1.1] tracking-tight mb-6 text-balance">
      An extremely fast security scanner, written in Rust.
    </h1>
    <p class="text-noir-400 text-sm sm:text-lg leading-relaxed mb-8 max-w-xl mx-auto">
      Cross-file taint tracking, 196 built-in rules, and a post-quantum crypto audit in a single binary. Free and open source.
    </p>
    <InstallTabs id="hero" />
  </div>
</section>
