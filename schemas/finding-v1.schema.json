{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foxguard.dev/schemas/finding-v1.schema.json",
  "title": "Foxguard Finding v1",
  "type": "object",
  "required": [
    "rule_id", "severity", "cwe", "description", "file", "line", "column",
    "end_line", "end_column", "snippet", "confidence"
  ],
  "properties": {
    "rule_id": { "type": "string" },
    "severity": { "enum": ["low", "medium", "high", "critical"] },
    "cwe": { "type": ["string", "null"] },
    "description": { "type": "string" },
    "file": { "type": "string" },
    "line": { "type": "integer", "minimum": 1 },
    "column": { "type": "integer", "minimum": 1 },
    "end_line": { "type": "integer", "minimum": 1 },
    "end_column": { "type": "integer", "minimum": 1 },
    "snippet": { "type": "string" },
    "source_line": { "type": "integer", "minimum": 1 },
    "source_description": { "type": "string" },
    "sink_line": { "type": "integer", "minimum": 1 },
    "sink_description": { "type": "string" },
    "fix_suggestion": { "type": "string" },
    "sink_start_byte": { "type": "integer", "minimum": 0 },
    "sink_end_byte": { "type": "integer", "minimum": 0 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "taint_hops": { "type": "integer", "minimum": 0, "maximum": 255 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "crypto_algorithm": { "type": "string" },
    "cnsa2_deadline": { "type": "string" },
    "dep_name": { "type": "string" },
    "dep_version": { "type": "string" },
    "dep_ecosystem": { "type": "string" },
    "dep_purl": { "type": "string" },
    "dep_vulnerability_id": { "type": "string" },
    "dep_fixed_version": { "type": "string" },
    "dep_source": { "type": "string" },
    "dep_vulnerability_severity": { "type": "string" },
    "dep_path": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
